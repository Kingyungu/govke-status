# ── Public (safe to expose to browser) ──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://status.wahenga.co.uk

# ── Server-side only (never expose to browser) ──────────────────────
# Your Supabase project URL (found in Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Your Supabase service role key (Settings → API → service_role)
# WARNING: Has full DB access — never commit this value
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# A random secret to protect the /api/cron/check endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=replace_with_a_random_string
